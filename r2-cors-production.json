[
  {
    "allowed_origins": [
      "https://yoom.cihconsultingllc.com",
      "http://localhost:3000",
      "http://localhost:3001"
    ],
    "allowed_methods": ["PUT", "GET", "HEAD", "OPTIONS"],
    "allowed_headers": [
      "Content-Type",
      "X-Amz-Content-Sha256",
      "X-Amz-Date",
